    group "Prod" {
        msProd = container "Prod Microservices" "бизнес логика после миграции" "${MS_TECHNOLOGY}" "Generalization, Prod, Service"
        msBroker = container "Broker" "среда для EDA" "Kafka" "Generalization, Broker"
        msDatabases = container "Databases" "Хранилища" "PostgreSQL/Redis/Clickhouse" "Generalization, Database"
    }
    msProd -> msBroker "Publish prod events" "Publish" "Publish"
    msBroker -> msProd "Consume prod events" "Subscribe" "Subscribe"

