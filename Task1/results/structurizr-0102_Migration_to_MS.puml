rectangle "==Пассажир\n<size:16>[Person]</size>\n\nЗаказывает, отслеживает и оплачивает поездки" <<Element-RWxlbWVudCxQZXJzb24=>> as Пассажир
rectangle "==Водитель\n<size:16>[Person]</size>\n\nПринимает заказы и получает выплаты" <<Element-RWxlbWVudCxQZXJzb24=>> as Водитель
rectangle "==Бухгалтер\n<size:16>[Person]</size>\n\nКонтролирует выплаты водителям" <<Element-RWxlbWVudCxQZXJzb24=>> as Бухгалтер

rectangle "GoFuture Platform\n<size:16>[Software System]</size>" <<Boundary-R29GdXR1cmUgUGxhdGZvcm0=>> {
  rectangle "Монолит\n<size:16>[Container: Django App]</size>" <<Boundary-0JzQvtC90L7Qu9C40YI=>> {
    rectangle "==Legacy Domains\n<size:16>[Component]</size>\n\nДомены бизнес логики до миграции" <<Element-RWxlbWVudCxDb21wb25lbnQ=>> as GoFuturePlatform.Монолит.LegacyDomains
    rectangle "==Anti-Corruption Component\n<size:16>[Component: ???]</size>\n\nОбеспечивает обратную совместимость внутренних связей при миграции." <<Element-RWxlbWVudCxDb21wb25lbnQ=>> as GoFuturePlatform.Монолит.AntiCorruptionComponent
  }

  rectangle "API Gateway\n<size:16>[Container: ???]</size>" <<Boundary-QVBJIEdhdGV3YXk=>> {
    rectangle "==Authorization + Legacy Auth Adapter\n<size:16>[Component]</size>\n\nПринимает старые session_id, выдает JWT" <<Element-RWxlbWVudCxDb21wb25lbnQ=>> as GoFuturePlatform.APIGateway.AuthorizationLegacyAuthAdapter
    rectangle "==Anti-Corruption Layer\n<size:16>[Component: ???]</size>\n\nТрансформирует v1 → v2\nРоутит на монолит или микросервис по feature flag\nПерехватывает прямые вызовы внутри монолита" <<Element-RWxlbWVudCxDb21wb25lbnQ=>> as GoFuturePlatform.APIGateway.AntiCorruptionLayer
    rectangle "==Routing\n<size:16>[Component]</size>\n\nМаршрутизация" <<Element-RWxlbWVudCxDb21wb25lbnQsSW5mcmFzdHJ1Y3R1cmU=>> as GoFuturePlatform.APIGateway.Routing
  }

  rectangle "==Пассажирское приложение\n<size:16>[Container: Native]</size>\n\niOS/Android/Huawei" <<Element-RWxlbWVudA==>> as GoFuturePlatform.Пассажирскоеприложение
  rectangle "==Водительское приложение\n<size:16>[Container: Native]</size>\n\niOS/Android/Huawei" <<Element-RWxlbWVudA==>> as GoFuturePlatform.Водительскоеприложение
  rectangle "==Корпоративный веб-портал\n<size:16>[Container: Native, UI, Entrance]</size>\n\nWeb Application" <<Element-RWxlbWVudA==>> as GoFuturePlatform.Корпоративныйвебпортал
  rectangle "==Админ-панель\n<size:16>[Container: Web Application]</size>\n\nУправление выплатами" <<Element-RWxlbWVudA==>> as GoFuturePlatform.Админпанель
  queue "==Брокер сообщений обратной совместимости\n<size:16>[Container: RabbitMQ]</size>\n\nОчередь задач" <<Element-RWxlbWVudCxCcm9rZXI=>> as GoFuturePlatform.Брокерсообщенийобратнойсовместимости
  rectangle "==Prod Microservices\n<size:16>[Container: Python/Faust Streaming]</size>\n\nбизнес логика после миграции" <<Element-RWxlbWVudCxQcm9k>> as GoFuturePlatform.ProdMicroservices
  queue "==Broker\n<size:16>[Container: Kafka]</size>\n\nсреда для EDA" <<Element-RWxlbWVudCxCcm9rZXI=>> as GoFuturePlatform.Broker
  rectangle "==Identity Service\n<size:16>[Container: Keycloak]</size>\n\nВыпускает JWT для микросервисов" <<Element-RWxlbWVudCxJbmZyYXN0cnVjdHVyZQ==>> as GoFuturePlatform.IdentityService
}

Пассажир --> GoFuturePlatform.Пассажирскоеприложение <<Relationship-UmVsYXRpb25zaGlw>> : "Использует"
Водитель --> GoFuturePlatform.Водительскоеприложение <<Relationship-UmVsYXRpb25zaGlw>> : "Использует"
Бухгалтер --> GoFuturePlatform.Админпанель <<Relationship-UmVsYXRpb25zaGlw>> : "Использует"
GoFuturePlatform.Монолит.LegacyDomains --> GoFuturePlatform.Монолит.AntiCorruptionComponent <<Relationship-UmVsYXRpb25zaGlw>> : "Обращаются к мигрировашим доменам\n<size:16>[Django]</size>"
GoFuturePlatform.Монолит.LegacyDomains --> GoFuturePlatform.Брокерсообщенийобратнойсовместимости <<Relationship-UmVsYXRpb25zaGlwLFB1Ymxpc2g=>> : "Прежние события\n<size:16>[AMQP Publish]</size>"
GoFuturePlatform.Брокерсообщенийобратнойсовместимости --> GoFuturePlatform.Монолит.LegacyDomains <<Relationship-UmVsYXRpb25zaGlwLFN1YnNjcmliZQ==>> : "Прежние события\n<size:16>[AMQP Subscribe]</size>"
GoFuturePlatform.APIGateway.Routing --> GoFuturePlatform.APIGateway.AntiCorruptionLayer <<Relationship-UmVsYXRpb25zaGlw>> : "Маршрутизирует старые связи"
GoFuturePlatform.APIGateway.AuthorizationLegacyAuthAdapter --> GoFuturePlatform.IdentityService <<Relationship-UmVsYXRpb25zaGlw>> : "Обменивает session_id на JWT\n<size:16>[Migration]</size>"
GoFuturePlatform.APIGateway.AuthorizationLegacyAuthAdapter --> GoFuturePlatform.Монолит.AntiCorruptionComponent <<Relationship-UmVsYXRpb25zaGlw>> : "Валидирует SessionId\n<size:16>[???]</size>"
GoFuturePlatform.APIGateway.AntiCorruptionLayer --> GoFuturePlatform.Монолит.LegacyDomains <<Relationship-UmVsYXRpb25zaGlw>> : "Перенаправляет legacy связи\n<size:16>[???]</size>"
GoFuturePlatform.APIGateway.AntiCorruptionLayer --> GoFuturePlatform.ProdMicroservices <<Relationship-UmVsYXRpb25zaGlw>> : "Трансформирует legacy связи\n<size:16>[???]</size>"
GoFuturePlatform.Монолит.AntiCorruptionComponent --> GoFuturePlatform.ProdMicroservices <<Relationship-UmVsYXRpb25zaGlw>> : "Трансформирует legacy связи\n<size:16>[???]</size>"
GoFuturePlatform.ProdMicroservices --> GoFuturePlatform.Broker <<Relationship-UmVsYXRpb25zaGlwLFB1Ymxpc2g=>> : "Publish prod events\n<size:16>[Publish]</size>"
GoFuturePlatform.Broker --> GoFuturePlatform.ProdMicroservices <<Relationship-UmVsYXRpb25zaGlwLFN1YnNjcmliZQ==>> : "Consume prod events\n<size:16>[Subscribe]</size>"
GoFuturePlatform.APIGateway.AuthorizationLegacyAuthAdapter --> GoFuturePlatform.IdentityService <<Relationship-UmVsYXRpb25zaGlw>> : "Получает сертификат авторизации"
GoFuturePlatform.Пассажирскоеприложение --> GoFuturePlatform.APIGateway.Routing <<Relationship-UmVsYXRpb25zaGlw>> : "Создает заказы\n<size:16>[HTTPS/REST API]</size>"
GoFuturePlatform.Водительскоеприложение --> GoFuturePlatform.APIGateway.Routing <<Relationship-UmVsYXRpb25zaGlw>> : "Обновляет статус\n<size:16>[HTTPS/REST API]</size>"
GoFuturePlatform.Корпоративныйвебпортал --> GoFuturePlatform.APIGateway.Routing <<Relationship-UmVsYXRpb25zaGlw>> : "Просмотр заказов\n<size:16>[HTTPS/REST API]</size>"
GoFuturePlatform.Админпанель --> GoFuturePlatform.APIGateway.Routing <<Relationship-UmVsYXRpb25zaGlw>> : "Управление выплатами\n<size:16>[HTTPS/REST API]</size>"
GoFuturePlatform.APIGateway.Routing --> GoFuturePlatform.APIGateway.AuthorizationLegacyAuthAdapter <<Relationship-UmVsYXRpb25zaGlw>> : "Авторизует"
GoFuturePlatform.APIGateway.Routing --> GoFuturePlatform.ProdMicroservices <<Relationship-UmVsYXRpb25zaGlw>> : "Маршрутизирует новые связи"

@enduml