@startuml
title <size:24>Миграция на микросервисы</size>

set separator none
top to bottom direction

<style>
  root {
    BackgroundColor: #ffffff
    FontColor: #444444
  }
</style>

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Container>
!include <C4/C4_Component>

AddElementTag("Container,Broker", $bgColor="#4b7bec", $borderColor="#3456a5", $fontColor="#ffffff", $sprite="", $shadowing="", $borderStyle="solid")
AddElementTag("Container,Infrastructure", $bgColor="#2c3e50", $borderColor="#ffffff", $fontColor="#ffffff", $sprite="", $shadowing="", $borderStyle="solid")
AddElementTag("Element", $bgColor="#ffffff", $borderColor="#444444", $fontColor="#444444", $sprite="", $shadowing="", $borderStyle="solid")
AddElementTag("Component", $bgColor="#85bbf0", $borderColor="#5d82a8", $fontColor="#000000", $sprite="", $shadowing="", $borderStyle="solid")
AddElementTag("Container", $bgColor="#1168bd", $borderColor="#0b4884", $fontColor="#ffffff", $sprite="", $shadowing="", $borderStyle="solid")

AddRelTag("Relationship", $textColor="#424242", $lineColor="#424242", $lineStyle = DashedLine())
AddRelTag("Publish", $textColor="#e67e22", $lineColor="#e67e22", $lineStyle = DashedLine())
AddRelTag("Subscribe", $textColor="#f1c40f", $lineColor="#f1c40f", $lineStyle = DashedLine())

AddBoundaryTag("Container", $bgColor="#ffffff", $borderColor="#0b4884", $fontColor="#0b4884", $shadowing="", $borderStyle="solid")

Person(Пассажир, "Пассажир", $descr="Заказывает, отслеживает и оплачивает поездки", $tags="Element", $link="")
Person(Водитель, "Водитель", $descr="Принимает заказы и получает выплаты", $tags="Element", $link="")
Person(Бухгалтер, "Бухгалтер", $descr="Контролирует выплаты водителям", $tags="Element", $link="")

System_Boundary("GoFuturePlatform_boundary", "GoFuture Platform", $tags="Element") {
  Container_Boundary("GoFuturePlatform.Монолит_boundary", "Монолит", $tags="Container") {
    Component(GoFuturePlatform.Монолит.LegacyDomains, "Legacy Domains", $techn="", $descr="Домены бизнес логики до миграции", $tags="Component", $link="")
    Component(GoFuturePlatform.Монолит.AntiCorruptionComponent, "Anti-Corruption Component", $techn="???", $descr="Обеспечивает обратную совместимость внутренних связей при миграции.", $tags="Component", $link="")
  }

  Container(GoFuturePlatform.Пассажирскоеприложение, "Пассажирское приложение", $techn="Native", $descr="iOS/Android/Huawei", $tags="Container", $link="")
  Container(GoFuturePlatform.Водительскоеприложение, "Водительское приложение", $techn="Native", $descr="iOS/Android/Huawei", $tags="Container", $link="")
  Container(GoFuturePlatform.Корпоративныйвебпортал, "Корпоративный веб-портал", $techn="Native, UI, Entrance", $descr="Web Application", $tags="Container", $link="")
  Container(GoFuturePlatform.Админпанель, "Админ-панель", $techn="Web Application", $descr="Управление выплатами", $tags="Container", $link="")
  ContainerQueue(GoFuturePlatform.Брокерсообщенийобратнойсовместимости, "Брокер сообщений обратной совместимости", $techn="RabbitMQ", $descr="Очередь задач", $tags="Container,Broker", $link="")
  Container(GoFuturePlatform.ProdMicroservices, "Prod Microservices", $techn="Python/Faust Streaming", $descr="бизнес логика после миграции", $tags="Container", $link="")
  ContainerQueue(GoFuturePlatform.Broker, "Broker", $techn="Kafka", $descr="среда для EDA", $tags="Container,Broker", $link="")
  Container(GoFuturePlatform.IdentityService, "Identity Service", $techn="Keycloak", $descr="Выпускает JWT для микросервисов", $tags="Container,Infrastructure", $link="")
  Container(GoFuturePlatform.APIGateway, "API Gateway", $techn="???", $descr="Единая точка входа, Auth, Rate Limiting", $tags="Container,Infrastructure", $link="")
}

Rel(Пассажир, GoFuturePlatform.Пассажирскоеприложение, "Использует", $techn="", $tags="Relationship", $link="")
Rel(Водитель, GoFuturePlatform.Водительскоеприложение, "Использует", $techn="", $tags="Relationship", $link="")
Rel(Бухгалтер, GoFuturePlatform.Админпанель, "Использует", $techn="", $tags="Relationship", $link="")
Rel(GoFuturePlatform.Монолит.LegacyDomains, GoFuturePlatform.Монолит.AntiCorruptionComponent, "Обращаются к мигрировашим доменам", $techn="Django", $tags="Relationship", $link="")
Rel(GoFuturePlatform.Монолит.LegacyDomains, GoFuturePlatform.Брокерсообщенийобратнойсовместимости, "Прежние события", $techn="AMQP Publish", $tags="Publish", $link="")
Rel(GoFuturePlatform.Брокерсообщенийобратнойсовместимости, GoFuturePlatform.Монолит.LegacyDomains, "Прежние события", $techn="AMQP Subscribe", $tags="Subscribe", $link="")
Rel(GoFuturePlatform.APIGateway, GoFuturePlatform.Монолит.AntiCorruptionComponent, "Валидирует SessionId", $techn="???", $tags="Relationship", $link="")
Rel(GoFuturePlatform.APIGateway, GoFuturePlatform.Монолит.LegacyDomains, "Перенаправляет legacy связи", $techn="???", $tags="Relationship", $link="")
Rel(GoFuturePlatform.Монолит.AntiCorruptionComponent, GoFuturePlatform.ProdMicroservices, "Трансформирует legacy связи", $techn="???", $tags="Relationship", $link="")
Rel(GoFuturePlatform.ProdMicroservices, GoFuturePlatform.Broker, "Publish prod events", $techn="Publish", $tags="Publish", $link="")
Rel(GoFuturePlatform.Broker, GoFuturePlatform.ProdMicroservices, "Consume prod events", $techn="Subscribe", $tags="Subscribe", $link="")
Rel(GoFuturePlatform.APIGateway, GoFuturePlatform.IdentityService, "Получает сертификат авторизации", $techn="", $tags="Relationship", $link="")
Rel(GoFuturePlatform.Пассажирскоеприложение, GoFuturePlatform.APIGateway, "Создает заказы", $techn="HTTPS/REST API", $tags="Relationship", $link="")
Rel(GoFuturePlatform.Водительскоеприложение, GoFuturePlatform.APIGateway, "Обновляет статус", $techn="HTTPS/REST API", $tags="Relationship", $link="")
Rel(GoFuturePlatform.Корпоративныйвебпортал, GoFuturePlatform.APIGateway, "Просмотр заказов", $techn="HTTPS/REST API", $tags="Relationship", $link="")
Rel(GoFuturePlatform.Админпанель, GoFuturePlatform.APIGateway, "Управление выплатами", $techn="HTTPS/REST API", $tags="Relationship", $link="")
Rel(GoFuturePlatform.APIGateway, GoFuturePlatform.ProdMicroservices, "Маршрутизирует новые связи", $techn="", $tags="Relationship", $link="")

SHOW_LEGEND(true)
hide stereotypes
@enduml