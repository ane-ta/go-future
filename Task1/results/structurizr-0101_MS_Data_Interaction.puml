    database "==БД Analytics\n<size:16>[Container: PostgreSQL RDS]</size>\n\n???" <<Element-RWxlbWVudCxQcm9kLERhdGFiYXNl>> as GoFuturePlatform.БДAnalytics
  }

  rectangle "Booking" <<Group-Qm9va2luZw==>> as groupQm9va2luZw== {
    rectangle "==Booking Service\n<size:16>[Container: Python/Faust Streaming]</size>\n\nУправление бронированиями" <<Element-RWxlbWVudCxQcm9k>> as GoFuturePlatform.BookingService
