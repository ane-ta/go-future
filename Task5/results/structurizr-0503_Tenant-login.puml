@startuml
title <size:24>Обработка запроса для партнера</size>

set separator none
top to bottom direction
hide stereotype

<style>
  root {
    BackgroundColor: #ffffff;
    FontColor: #444444;
  }
  // Element,Broker
  .Element-RWxlbWVudCxCcm9rZXI= {
    BackgroundColor: #4b7bec;
    LineColor: #3456a5;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Component,MultiTenant
  .Element-RWxlbWVudCxDb21wb25lbnQsTXVsdGlUZW5hbnQ= {
    BackgroundColor: #2980b9;
    LineColor: #1c5981;
    LineStyle: 0;
    LineThickness: 2;
    RoundCorner: 20;
    FontColor: #ffffff;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Infrastructure
  .Element-RWxlbWVudCxJbmZyYXN0cnVjdHVyZQ== {
    BackgroundColor: #555555;
    LineColor: #3b3b3b;
    LineStyle: 0;
    LineThickness: 2;
    RoundCorner: 20;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Person
  .Element-RWxlbWVudCxQZXJzb24= {
    BackgroundColor: #08427b;
    LineColor: #052e56;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Relationship
  .Relationship-UmVsYXRpb25zaGlw {
    LineThickness: 2;
    LineStyle: 10-10;
    LineColor: #444444;
    FontColor: #444444;
    FontSize: 24;
  }
  // API Gateway
  .Boundary-QVBJIEdhdGV3YXk= {
    BackgroundColor: #ffffff;
    LineColor: #3b3b3b;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
  }
  // GoFuture Platform
  .Boundary-R29GdXR1cmUgUGxhdGZvcm0= {
    BackgroundColor: #ffffff;
    LineColor: #000000;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
  }
  // Prod Microservices
  .Boundary-UHJvZCBNaWNyb3NlcnZpY2Vz {
    BackgroundColor: #ffffff;
    LineColor: #0b4884;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
  }
  // БД Микросервисов
  .Boundary-0JHQlCDQnNC40LrRgNC+0YHQtdGA0LLQuNGB0L7Qsg== {
    BackgroundColor: #ffffff;
    LineColor: #134481;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
  }
</style>

rectangle "==Partner user\n<size:16>[Person]</size>\n\nСотрудник таксопарка-партнера" <<Element-RWxlbWVudCxQZXJzb24=>> as Partneruser

rectangle "GoFuture Platform\n<size:16>[Software System]</size>" <<Boundary-R29GdXR1cmUgUGxhdGZvcm0=>> {
  rectangle "Prod Microservices\n<size:16>[Container: Python/Faust Streaming]</size>" <<Boundary-UHJvZCBNaWNyb3NlcnZpY2Vz>> {
    rectangle "==Dynamic DataSource Router\n<size:16>[Component]</size>\n\nЗадает схему как контекст последующих SQL запросов" <<Element-RWxlbWVudCxDb21wb25lbnQsTXVsdGlUZW5hbnQ=>> as GoFuturePlatform.ProdMicroservices.DynamicDataSourceRouter
    rectangle "==Event Publisher\n<size:16>[Component]</size>\n\nПередает в событиях tenant_id" <<Element-RWxlbWVudCxDb21wb25lbnQsTXVsdGlUZW5hbnQ=>> as GoFuturePlatform.ProdMicroservices.EventPublisher
  }

  rectangle "БД Микросервисов\n<size:16>[Container: PostgreSQL]</size>" <<Boundary-0JHQlCDQnNC40LrRgNC+0YHQtdGA0LLQuNGB0L7Qsg==>> {
    rectangle "==Partner database schema\n<size:16>[Component: PostgreSQL]</size>\n\nХранение данных партнеров в изолированных схемах (Schema-per-tenant)" <<Element-RWxlbWVudCxDb21wb25lbnQsTXVsdGlUZW5hbnQ=>> as GoFuturePlatform.БДМикросервисов.Partnerdatabaseschema
  }

  rectangle "API Gateway\n<size:16>[Container: ???]</size>" <<Boundary-QVBJIEdhdGV3YXk=>> {
    rectangle "==Tenant Id из JWT\n<size:16>[Component]</size>\n\nИзвлекает tenant_id из JWT и помещение его в заголовок" <<Element-RWxlbWVudCxDb21wb25lbnQsTXVsdGlUZW5hbnQ=>> as GoFuturePlatform.APIGateway.TenantIdизJWT
  }

  queue "==Брокер сообщений EDA\n<size:16>[Container: Kafka]</size>\n\nДоменные события, CDC события, события аналитики" <<Element-RWxlbWVudCxCcm9rZXI=>> as GoFuturePlatform.БрокерсообщенийEDA
  rectangle "==Identity Service\n<size:16>[Container: Keycloak]</size>\n\nВыпускает JWT для микросервисов" <<Element-RWxlbWVudCxJbmZyYXN0cnVjdHVyZQ==>> as GoFuturePlatform.IdentityService
}

queue "==Брокер сообщений EDA\n<size:16>[Container: Kafka]</size>\n\nДоменные события, CDC события, события аналитики" <<Element-RWxlbWVudCxCcm9rZXI=>> as GoFuturePlatform.БрокерсообщенийEDA
rectangle "==Identity Service\n<size:16>[Container: Keycloak]</size>\n\nВыпускает JWT для микросервисов" <<Element-RWxlbWVudCxJbmZyYXN0cnVjdHVyZQ==>> as GoFuturePlatform.IdentityService
rectangle "==Partner user\n<size:16>[Person]</size>\n\nСотрудник таксопарка-партнера" <<Element-RWxlbWVudCxQZXJzb24=>> as Partneruser

Partneruser --> GoFuturePlatform.IdentityService <<Relationship-UmVsYXRpb25zaGlw>> : "1: Логинится в Realm тенанта (SSO) и получает свой JWT"
GoFuturePlatform.IdentityService --> Partneruser <<Relationship-UmVsYXRpb25zaGlw>> : "2: Выдает JWT токен с tenant_id"
Partneruser --> GoFuturePlatform.APIGateway.TenantIdизJWT <<Relationship-UmVsYXRpb25zaGlw>> : "3: Запросы к платформе (с JWT)"
GoFuturePlatform.APIGateway.TenantIdизJWT --> GoFuturePlatform.ProdMicroservices.DynamicDataSourceRouter <<Relationship-UmVsYXRpb25zaGlw>> : "4: Запросы с tenant_id в заголовках"
GoFuturePlatform.ProdMicroservices.DynamicDataSourceRouter --> GoFuturePlatform.БДМикросервисов.Partnerdatabaseschema <<Relationship-UmVsYXRpb25zaGlw>> : "5: SET search_path TO tenant_schema"
GoFuturePlatform.APIGateway.TenantIdизJWT --> GoFuturePlatform.ProdMicroservices.EventPublisher <<Relationship-UmVsYXRpb25zaGlw>> : "6: Запросы с tenant_id в заголовках"
GoFuturePlatform.ProdMicroservices.EventPublisher --> GoFuturePlatform.БрокерсообщенийEDA <<Relationship-UmVsYXRpb25zaGlw>> : "7: Публикует все события с tenant_id\n<size:16>[Publish]</size>"

@enduml