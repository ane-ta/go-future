@startuml
title <size:24>Создание окружения для нового партнера</size>

set separator none
top to bottom direction
hide stereotype

<style>
  root {
    BackgroundColor: #ffffff;
    FontColor: #444444;
  }
  // Element,Component,MultiTenant
  .Element-RWxlbWVudCxDb21wb25lbnQsTXVsdGlUZW5hbnQ= {
    BackgroundColor: #2980b9;
    LineColor: #1c5981;
    LineStyle: 0;
    LineThickness: 2;
    RoundCorner: 20;
    FontColor: #ffffff;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,MultiTenant
  .Element-RWxlbWVudCxNdWx0aVRlbmFudA== {
    BackgroundColor: #2980b9;
    LineColor: #1c5981;
    LineStyle: 0;
    LineThickness: 2;
    RoundCorner: 20;
    FontColor: #ffffff;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Person
  .Element-RWxlbWVudCxQZXJzb24= {
    BackgroundColor: #08427b;
    LineColor: #052e56;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Relationship
  .Relationship-UmVsYXRpb25zaGlw {
    LineThickness: 2;
    LineStyle: 10-10;
    LineColor: #444444;
    FontColor: #444444;
    FontSize: 24;
  }
  // GoFuture Platform
  .Boundary-R29GdXR1cmUgUGxhdGZvcm0= {
    BackgroundColor: #ffffff;
    LineColor: #000000;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
  }
  // Identity Service
  .Boundary-SWRlbnRpdHkgU2VydmljZQ== {
    BackgroundColor: #ffffff;
    LineColor: #3b3b3b;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
  }
  // БД Микросервисов
  .Boundary-0JHQlCDQnNC40LrRgNC+0YHQtdGA0LLQuNGB0L7Qsg== {
    BackgroundColor: #ffffff;
    LineColor: #134481;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
  }
</style>

rectangle "==GoFuture Admin\n<size:16>[Person]</size>\n\nСотрудник платформы, управляющий партнерами" <<Element-RWxlbWVudCxQZXJzb24=>> as GoFutureAdmin

rectangle "GoFuture Platform\n<size:16>[Software System]</size>" <<Boundary-R29GdXR1cmUgUGxhdGZvcm0=>> {
  rectangle "БД Микросервисов\n<size:16>[Container: PostgreSQL]</size>" <<Boundary-0JHQlCDQnNC40LrRgNC+0YHQtdGA0LLQuNGB0L7Qsg==>> {
    rectangle "==Partner database schema\n<size:16>[Component: PostgreSQL]</size>\n\nХранение данных партнеров в изолированных схемах (Schema-per-tenant)" <<Element-RWxlbWVudCxDb21wb25lbnQsTXVsdGlUZW5hbnQ=>> as GoFuturePlatform.БДМикросервисов.Partnerdatabaseschema
  }

  rectangle "Identity Service\n<size:16>[Container: Keycloak]</size>" <<Boundary-SWRlbnRpdHkgU2VydmljZQ==>> {
    rectangle "==Tenant realm\n<size:16>[Component]</size>" <<Element-RWxlbWVudCxDb21wb25lbnQsTXVsdGlUZW5hbnQ=>> as GoFuturePlatform.IdentityService.Tenantrealm
  }

  rectangle "==Partner Management Service\n<size:16>[Container]</size>" <<Element-RWxlbWVudCxNdWx0aVRlbmFudA==>> as GoFuturePlatform.PartnerManagementService
  rectangle "==Partner Onboarding Service\n<size:16>[Container: Go / Python]</size>\n\nАвтоматизация создания новых тенантов" <<Element-RWxlbWVudCxNdWx0aVRlbmFudA==>> as GoFuturePlatform.PartnerOnboardingService
}

rectangle "==GoFuture Admin\n<size:16>[Person]</size>\n\nСотрудник платформы, управляющий партнерами" <<Element-RWxlbWVudCxQZXJzb24=>> as GoFutureAdmin
rectangle "==Partner Management Service\n<size:16>[Container]</size>" <<Element-RWxlbWVudCxNdWx0aVRlbmFudA==>> as GoFuturePlatform.PartnerManagementService
rectangle "==Partner Onboarding Service\n<size:16>[Container: Go / Python]</size>\n\nАвтоматизация создания новых тенантов" <<Element-RWxlbWVudCxNdWx0aVRlbmFudA==>> as GoFuturePlatform.PartnerOnboardingService

GoFutureAdmin --> GoFuturePlatform.PartnerManagementService <<Relationship-UmVsYXRpb25zaGlw>> : "1: Создает запись для нового партнера"
GoFutureAdmin --> GoFuturePlatform.PartnerOnboardingService <<Relationship-UmVsYXRpb25zaGlw>> : "2: Инициирует создание нового партнера"
GoFuturePlatform.PartnerOnboardingService --> GoFuturePlatform.IdentityService.Tenantrealm <<Relationship-UmVsYXRpb25zaGlw>> : "3: Создает Realm и Admin учетку для партнера\nКонфигурирует SSO для партнера\n<size:16>[gRPC]</size>"
GoFuturePlatform.PartnerOnboardingService --> GoFuturePlatform.БДМикросервисов.Partnerdatabaseschema <<Relationship-UmVsYXRpb25zaGlw>> : "4: Создает изолированную SQL Schema (CREATE SCHEMA)\n<size:16>[SQL]</size>"

@enduml