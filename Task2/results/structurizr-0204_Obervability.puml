@startuml
title <size:24>Система обеспечения наблюдаемости</size>

set separator none
top to bottom direction
hide stereotype

<style>
  root {
    BackgroundColor: #ffffff;
    FontColor: #444444;
  }
  // Element,AnalyticsPipe
  .Element-RWxlbWVudCxBbmFseXRpY3NQaXBl {
    BackgroundColor: #218c74;
    LineColor: #176251;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Broker
  .Element-RWxlbWVudCxCcm9rZXI= {
    BackgroundColor: #4b7bec;
    LineColor: #3456a5;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Database
  .Element-RWxlbWVudCxEYXRhYmFzZQ== {
    BackgroundColor: #1c62b9;
    LineColor: #134481;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Observability
  .Element-RWxlbWVudCxPYnNlcnZhYmlsaXR5 {
    BackgroundColor: #8e44ad;
    LineColor: #632f79;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Person
  .Element-RWxlbWVudCxQZXJzb24= {
    BackgroundColor: #08427b;
    LineColor: #052e56;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Prod
  .Element-RWxlbWVudCxQcm9k {
    BackgroundColor: #1168bd;
    LineColor: #0b4884;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Relationship
  .Relationship-UmVsYXRpb25zaGlw {
    LineThickness: 2;
    LineStyle: 10-10;
    LineColor: #444444;
    FontColor: #444444;
    FontSize: 24;
  }
  // Relationship,Publish
  .Relationship-UmVsYXRpb25zaGlwLFB1Ymxpc2g= {
    LineThickness: 2;
    LineStyle: 10-10;
    LineColor: #e67e22;
    FontColor: #e67e22;
    FontSize: 24;
  }
  // Relationship,Subscribe
  .Relationship-UmVsYXRpb25zaGlwLFN1YnNjcmliZQ== {
    LineThickness: 2;
    LineStyle: 10-10;
    LineColor: #f1c40f;
    FontColor: #f1c40f;
    FontSize: 24;
  }
  // GoFuture Platform
  .Boundary-R29GdXR1cmUgUGxhdGZvcm0= {
    BackgroundColor: #ffffff;
    LineColor: #000000;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
  }
  // Analytics pipe
  .Group-QW5hbHl0aWNzIHBpcGU= {
    BackgroundColor: #ffffff;
    LineColor: #444444;
    LineStyle: 2-2;
    LineThickness: 2;
    FontColor: #444444;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
  }
  // Observability
  .Group-T2JzZXJ2YWJpbGl0eQ== {
    BackgroundColor: #ffffff;
    LineColor: #444444;
    LineStyle: 2-2;
    LineThickness: 2;
    FontColor: #444444;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
  }
  // Prod area
  .Group-UHJvZCBhcmVh {
    BackgroundColor: #ffffff;
    LineColor: #444444;
    LineStyle: 2-2;
    LineThickness: 2;
    FontColor: #444444;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
  }
</style>

rectangle "==SRE инженер\n<size:16>[Person]</size>\n\nМониторинг и поддержка" <<Element-RWxlbWVudCxQZXJzb24=>> as SREинженер

rectangle "GoFuture Platform\n<size:16>[Software System]</size>" <<Boundary-R29GdXR1cmUgUGxhdGZvcm0=>> {
  rectangle "Analytics pipe" <<Group-QW5hbHl0aWNzIHBpcGU=>> as groupQW5hbHl0aWNzIHBpcGU= {
    rectangle "==Analytics Db\n<size:16>[Container: ClickHouse]</size>\n\nХранение аналитических данных" <<Element-RWxlbWVudCxBbmFseXRpY3NQaXBl>> as GoFuturePlatform.AnalyticsDb
  }

  rectangle "Observability" <<Group-T2JzZXJ2YWJpbGl0eQ==>> as groupT2JzZXJ2YWJpbGl0eQ== {
    rectangle "==Хранилище трейсов\n<size:16>[Container: Grafana Tempo]</size>\n\nТрейсинг" <<Element-RWxlbWVudCxPYnNlcnZhYmlsaXR5>> as GoFuturePlatform.Хранилищетрейсов
    rectangle "==Prometheus\n<size:16>[Container: Monitoring system]</size>\n\nСбор метрик и мониторинг" <<Element-RWxlbWVudCxPYnNlcnZhYmlsaXR5>> as GoFuturePlatform.Prometheus
    rectangle "==Grafana\n<size:16>[Container: Grafana]</size>\n\nВизуализация метрик. Дашборды" <<Element-RWxlbWVudCxPYnNlcnZhYmlsaXR5>> as GoFuturePlatform.Grafana
    rectangle "==Alertmanager\n<size:16>[Container: Alertmanager]</size>\n\nАлертинг" <<Element-RWxlbWVudCxPYnNlcnZhYmlsaXR5>> as GoFuturePlatform.Alertmanager
    rectangle "==Loki\n<size:16>[Container: Loki]</size>\n\nСбор логов" <<Element-RWxlbWVudCxPYnNlcnZhYmlsaXR5>> as GoFuturePlatform.Loki
  }

  rectangle "Prod area" <<Group-UHJvZCBhcmVh>> as groupUHJvZCBhcmVh {
    rectangle "==Prod Microservices\n<size:16>[Container: Python/Faust Streaming]</size>\n\nбизнес логика после миграции" <<Element-RWxlbWVudCxQcm9k>> as GoFuturePlatform.ProdMicroservices
    queue "==Broker\n<size:16>[Container: Kafka]</size>\n\nсреда для EDA" <<Element-RWxlbWVudCxCcm9rZXI=>> as GoFuturePlatform.Broker
    database "==Databases\n<size:16>[Container: PostgreSQL/Redis/Clickhouse]</size>\n\nХранилища" <<Element-RWxlbWVudCxEYXRhYmFzZQ==>> as GoFuturePlatform.Databases
  }

  rectangle "==Агент телеметрии\n<size:16>[Container: Grafana Alloy Agent]</size>\n\nСбор и обработка телеметрии: метрики, логи, трейсы" <<Element-RWxlbWVudCxPYnNlcnZhYmlsaXR5>> as GoFuturePlatform.Агенттелеметрии
}

GoFuturePlatform.ProdMicroservices --> GoFuturePlatform.Агенттелеметрии <<Relationship-UmVsYXRpb25zaGlw>> : "Метрики\n<size:16>[prometheus_client lib]</size>"
GoFuturePlatform.Broker --> GoFuturePlatform.Агенттелеметрии <<Relationship-UmVsYXRpb25zaGlw>> : "Метрики очередей\n<size:16>[???]</size>"
GoFuturePlatform.Databases --> GoFuturePlatform.Агенттелеметрии <<Relationship-UmVsYXRpb25zaGlw>> : "Метрики БД\n<size:16>[???]</size>"
GoFuturePlatform.Агенттелеметрии --> GoFuturePlatform.Prometheus <<Relationship-UmVsYXRpb25zaGlw>> : "технические и бизнес метрики\n<size:16>[Metrics, Observability]</size>"
GoFuturePlatform.Grafana --> GoFuturePlatform.AnalyticsDb <<Relationship-UmVsYXRpb25zaGlw>> : "Бизнесовые метрики"
GoFuturePlatform.ProdMicroservices --> GoFuturePlatform.Агенттелеметрии <<Relationship-UmVsYXRpb25zaGlw>> : "структурированные логи\n<size:16>[stdout]</size>"
GoFuturePlatform.Broker --> GoFuturePlatform.Агенттелеметрии <<Relationship-UmVsYXRpb25zaGlw>> : "структурированные логи\n<size:16>[stdout]</size>"
GoFuturePlatform.Databases --> GoFuturePlatform.Агенттелеметрии <<Relationship-UmVsYXRpb25zaGlw>> : "структурированные логи\n<size:16>[stdout]</size>"
GoFuturePlatform.Агенттелеметрии --> GoFuturePlatform.Loki <<Relationship-UmVsYXRpb25zaGlw>> : "Logs\n<size:16>[Metrics, Observability]</size>"
GoFuturePlatform.ProdMicroservices --> GoFuturePlatform.Агенттелеметрии <<Relationship-UmVsYXRpb25zaGlw>> : "Трейсы\n<size:16>[Otel SDK]</size>"
GoFuturePlatform.Агенттелеметрии --> GoFuturePlatform.Хранилищетрейсов <<Relationship-UmVsYXRpb25zaGlw>> : "Трейсы\n<size:16>[OTLP]</size>"
GoFuturePlatform.Grafana --> GoFuturePlatform.Хранилищетрейсов <<Relationship-UmVsYXRpb25zaGlw>> : "Трейсы\n<size:16>[TraceQL]</size>"
GoFuturePlatform.Grafana --> GoFuturePlatform.Loki <<Relationship-UmVsYXRpb25zaGlw>> : "Логи\n<size:16>[LogQL]</size>"
GoFuturePlatform.Grafana --> GoFuturePlatform.Prometheus <<Relationship-UmVsYXRpb25zaGlw>> : "Метрики\n<size:16>[PromQL]</size>"
GoFuturePlatform.Prometheus --> GoFuturePlatform.Alertmanager <<Relationship-UmVsYXRpb25zaGlw>> : "Алерты\n<size:16>[Metrics, Observability]</size>"
GoFuturePlatform.Alertmanager --> SREинженер <<Relationship-UmVsYXRpb25zaGlw>> : "Приходят алерты\n<size:16>[Email/Slack/Pager]</size>"
SREинженер --> GoFuturePlatform.Alertmanager <<Relationship-UmVsYXRpb25zaGlw>> : "Настраивает алерты\n<size:16>[Metrics, Observability]</size>"
SREинженер --> GoFuturePlatform.Grafana <<Relationship-UmVsYXRpb25zaGlw>> : "Мониторит систему\n<size:16>[Metrics, Logs, Observability]</size>"
GoFuturePlatform.ProdMicroservices --> GoFuturePlatform.Broker <<Relationship-UmVsYXRpb25zaGlwLFB1Ymxpc2g=>> : "Publish prod events\n<size:16>[Publish]</size>"
GoFuturePlatform.Broker --> GoFuturePlatform.ProdMicroservices <<Relationship-UmVsYXRpb25zaGlwLFN1YnNjcmliZQ==>> : "Consume prod events\n<size:16>[Subscribe]</size>"

@enduml