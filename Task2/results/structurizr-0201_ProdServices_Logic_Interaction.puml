rectangle "==Яндекс Пэй\n<size:16>[Software System]</size>\n\nПлатежный шлюз" <<Element-RWxlbWVudCxFeHRlcm5hbA==>> as ЯндексПэй
rectangle "==Яндекс Карты\n<size:16>[Software System]</size>\n\nГеоданные и маршруты" <<Element-RWxlbWVudCxFeHRlcm5hbA==>> as ЯндексКарты
rectangle "==API Банка\n<size:16>[Software System]</size>\n\nБанковские выплаты" <<Element-RWxlbWVudCxFeHRlcm5hbA==>> as APIБанка
rectangle "==Firebase Cloud Messaging\n<size:16>[Software System]</size>\n\nPush iOS/Android" <<Element-RWxlbWVudCxFeHRlcm5hbA==>> as FirebaseCloudMessaging
rectangle "==Apple Push Notification\n<size:16>[Software System]</size>\n\nPush iOS" <<Element-RWxlbWVudCxFeHRlcm5hbA==>> as ApplePushNotification
rectangle "==Huawei Push Kit\n<size:16>[Software System]</size>\n\nPush Huawei" <<Element-RWxlbWVudCxFeHRlcm5hbA==>> as HuaweiPushKit

rectangle "GoFuture Platform\n<size:16>[Software System]</size>" <<Boundary-R29GdXR1cmUgUGxhdGZvcm0=>> {
  rectangle "Analytics" <<Group-QW5hbHl0aWNz>> as groupQW5hbHl0aWNz {
    rectangle "==Analytics Service\n<size:16>[Container: Python/Faust Streaming]</size>\n\nСбор аналитики" <<Element-RWxlbWVudCxQcm9k>> as GoFuturePlatform.AnalyticsService
    rectangle "==Analytics Service Tasks\n<size:16>[Container: Celery Task]</size>\n\nАсинхронная аналитика" <<Element-RWxlbWVudCxQcm9k>> as GoFuturePlatform.AnalyticsServiceTasks
  }

  rectangle "Booking" <<Group-Qm9va2luZw==>> as groupQm9va2luZw== {
    rectangle "==Booking Service\n<size:16>[Container: Python/Faust Streaming]</size>\n\nУправление бронированиями" <<Element-RWxlbWVudCxQcm9k>> as GoFuturePlatform.BookingService
  }

  rectangle "Drivers" <<Group-RHJpdmVycw==>> as groupRHJpdmVycw== {
    rectangle "==Driver Service\n<size:16>[Container: Python/Faust Streaming]</size>\n\nУправление водителями" <<Element-RWxlbWVudCxQcm9k>> as GoFuturePlatform.DriverService
  }

  rectangle "Fraud" <<Group-RnJhdWQ=>> as groupRnJhdWQ= {
    rectangle "==Fraud Service\n<size:16>[Container: Python/Faust Streaming]</size>\n\nОбнаружение мошенничества" <<Element-RWxlbWVudCxQcm9k>> as GoFuturePlatform.FraudService
  }

  rectangle "Geo" <<Group-R2Vv>> as groupR2Vv {
