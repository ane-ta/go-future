  }

  rectangle "Notification" <<Group-Tm90aWZpY2F0aW9u>> as groupTm90aWZpY2F0aW9u {
    rectangle "==Notification Service\n<size:16>[Container: Python/Faust Streaming]</size>\n\nУправление уведомлениями" <<Element-RWxlbWVudCxQcm9k>> as GoFuturePlatform.NotificationService
    rectangle "==Notification Service Tasks\n<size:16>[Container: Celery Task]</size>\n\nАсинхронные задачи уведомлений" <<Element-RWxlbWVudCxQcm9k>> as GoFuturePlatform.NotificationServiceTasks
  }

  rectangle "Orchestration" <<Group-T3JjaGVzdHJhdGlvbg==>> as groupT3JjaGVzdHJhdGlvbg== {
    rectangle "==Orchestration\n<size:16>[Container: Temporal Python SDK]</size>\n\nОркестрация" <<Element-RWxlbWVudCxQcm9k>> as GoFuturePlatform.Orchestration
