  }

  rectangle "Payouts" <<Group-UGF5b3V0cw==>> as groupUGF5b3V0cw== {
    rectangle "==Payouts Service\n<size:16>[Container: Python/Faust Streaming]</size>\n\nВыплаты водителям" <<Element-RWxlbWVudCxQcm9k>> as GoFuturePlatform.PayoutsService
    rectangle "==Payout Service Tasks\n<size:16>[Container: Celery Task]</size>\n\nАсинхронные задачи выплат" <<Element-RWxlbWVudCxQcm9k>> as GoFuturePlatform.PayoutServiceTasks
  }

  rectangle "Pricing" <<Group-UHJpY2luZw==>> as groupUHJpY2luZw== {
    rectangle "==Pricing Service\n<size:16>[Container: Python/Faust Streaming]</size>\n\nЦенообразование" <<Element-RWxlbWVudCxQcm9k>> as GoFuturePlatform.PricingService
  }

  queue "==Брокер сообщений EDA\n<size:16>[Container: Kafka]</size>\n\nДоменные события, CDC события, события аналитики" <<Element-RWxlbWVudCxCcm9rZXI=>> as GoFuturePlatform.БрокерсообщенийEDA
}

GoFuturePlatform.BookingService --> GoFuturePlatform.Orchestration <<Relationship-UmVsYXRpb25zaGlwLExvZ2ljQXBp>> : "инициирует SAGA\n<size:16>[синхронно]</size>"
