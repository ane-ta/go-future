@startuml

set separator none
hide stereotype

<style>
  root {
    BackgroundColor: #ffffff;
    FontColor: #444444;
  }
  // Element,AnalyticsPipe
  .Element-RWxlbWVudCxBbmFseXRpY3NQaXBl {
    BackgroundColor: #218c74;
    LineColor: #176251;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 200;
  }
  // Element,Broker
  .Element-RWxlbWVudCxCcm9rZXI= {
    BackgroundColor: #4b7bec;
    LineColor: #3456a5;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 200;
  }
  // Element,Prod
  .Element-RWxlbWVudCxQcm9k {
    BackgroundColor: #1168bd;
    LineColor: #0b4884;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 200;
  }
  // Element,Prod,Database,Cache
  .Element-RWxlbWVudCxQcm9kLERhdGFiYXNlLENhY2hl {
    BackgroundColor: #3498db;
    LineColor: #246a99;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #246a99;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 200;
  }
  // Relationship
  .Relationship-UmVsYXRpb25zaGlw {
    LineThickness: 2;
    LineStyle: 10-10;
    LineColor: #444444;
    FontColor: #444444;
    FontSize: 24;
  }
  // Relationship,Publish
  .Relationship-UmVsYXRpb25zaGlwLFB1Ymxpc2g= {
    LineThickness: 2;
    LineStyle: 10-10;
    LineColor: #e67e22;
    FontColor: #e67e22;
    FontSize: 24;
  }
  // Relationship,Subscribe
  .Relationship-UmVsYXRpb25zaGlwLFN1YnNjcmliZQ== {
    LineThickness: 2;
    LineStyle: 10-10;
    LineColor: #f1c40f;
    FontColor: #f1c40f;
    FontSize: 24;
  }
  // transparent element for relationships in legend
  .Element-Transparent {
    BackgroundColor: transparent;
    LineColor: transparent;
    FontColor: transparent;
  }
</style>

rectangle "==AnalyticsPipe" <<Element-RWxlbWVudCxBbmFseXRpY3NQaXBl>>

queue "==Broker" <<Element-RWxlbWVudCxCcm9rZXI=>>

rectangle "==Prod" <<Element-RWxlbWVudCxQcm9k>>

database "==Prod, Database, Cache" <<Element-RWxlbWVudCxQcm9kLERhdGFiYXNlLENhY2hl>>

rectangle "." <<.Element-Transparent>> as 1
1 --> 1 <<Relationship-UmVsYXRpb25zaGlw>> : "Relationship"

rectangle "." <<.Element-Transparent>> as 2
2 --> 2 <<Relationship-UmVsYXRpb25zaGlwLFB1Ymxpc2g=>> : "Publish"

rectangle "." <<.Element-Transparent>> as 3
3 --> 3 <<Relationship-UmVsYXRpb25zaGlwLFN1YnNjcmliZQ==>> : "Subscribe"

@enduml