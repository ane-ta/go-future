@startuml
title <size:24>Пересчет динамического ценообразования</size>\n<size:24>Surge</size>

set separator none
hide stereotype

<style>
  root {
    BackgroundColor: #ffffff;
    FontColor: #444444;
  }
  // Element,AnalyticsPipe
  .Element-RWxlbWVudCxBbmFseXRpY3NQaXBl {
    BackgroundColor: #218c74;
    LineColor: #176251;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Broker
  .Element-RWxlbWVudCxCcm9rZXI= {
    BackgroundColor: #4b7bec;
    LineColor: #3456a5;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Prod
  .Element-RWxlbWVudCxQcm9k {
    BackgroundColor: #1168bd;
    LineColor: #0b4884;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Prod,Database,Cache
  .Element-RWxlbWVudCxQcm9kLERhdGFiYXNlLENhY2hl {
    BackgroundColor: #3498db;
    LineColor: #246a99;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #246a99;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Relationship
  .Relationship-UmVsYXRpb25zaGlw {
    LineThickness: 2;
    LineStyle: 10-10;
    LineColor: #444444;
    FontColor: #444444;
    FontSize: 24;
  }
  // Relationship,Publish
  .Relationship-UmVsYXRpb25zaGlwLFB1Ymxpc2g= {
    LineThickness: 2;
    LineStyle: 10-10;
    LineColor: #e67e22;
    FontColor: #e67e22;
    FontSize: 24;
  }
  // Relationship,Subscribe
  .Relationship-UmVsYXRpb25zaGlwLFN1YnNjcmliZQ== {
    LineThickness: 2;
    LineStyle: 10-10;
    LineColor: #f1c40f;
    FontColor: #f1c40f;
    FontSize: 24;
  }
</style>

participant "Брокер сообщений EDA\n<size:16>[Container: Kafka]</size>" as GoFuturePlatform.БрокерсообщенийEDA <<Element-RWxlbWVudCxCcm9rZXI=>>
participant "ML Platform\n<size:16>[Container: Kubeflow / MLflow]</size>" as GoFuturePlatform.MLPlatform <<Element-RWxlbWVudCxBbmFseXRpY3NQaXBl>>
participant "Pricing Service\n<size:16>[Container: Python/Faust Streaming]</size>" as GoFuturePlatform.PricingService <<Element-RWxlbWVudCxQcm9k>>
database "Cache Pricing\n<size:16>[Container: Redis]</size>" as GoFuturePlatform.CachePricing <<Element-RWxlbWVudCxQcm9kLERhdGFiYXNlLENhY2hl>>
participant "Analytics Engine\n<size:16>[Container: Spark/Flink]</size>" as GoFuturePlatform.AnalyticsEngine <<Element-RWxlbWVudCxBbmFseXRpY3NQaXBl>>

GoFuturePlatform.БрокерсообщенийEDA -> GoFuturePlatform.MLPlatform <<Relationship-UmVsYXRpb25zaGlwLFN1YnNjcmliZQ==>> : 1: События для динамического ценообразования\n<size:16>[Subscribe]</size>
GoFuturePlatform.MLPlatform -> GoFuturePlatform.БрокерсообщенийEDA <<Relationship-UmVsYXRpb25zaGlwLFB1Ymxpc2g=>> : 2: SurgeFactorUpdated\n<size:16>[Publish]</size>
GoFuturePlatform.БрокерсообщенийEDA -> GoFuturePlatform.PricingService <<Relationship-UmVsYXRpb25zaGlwLFN1YnNjcmliZQ==>> : 3: SurgeFactorUpdated\n<size:16>[Subscribe]</size>
GoFuturePlatform.PricingService -> GoFuturePlatform.CachePricing <<Relationship-UmVsYXRpb25zaGlw>> : 4: Surge factor upsert\n<size:16>[Redis]</size>
GoFuturePlatform.БрокерсообщенийEDA -> GoFuturePlatform.AnalyticsEngine <<Relationship-UmVsYXRpb25zaGlwLFN1YnNjcmliZQ==>> : 5: События для переобучения ML\n<size:16>[Subscribe]</size>

@enduml