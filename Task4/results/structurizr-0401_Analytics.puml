@startuml
title <size:24>Аналитика BI и ML</size>

set separator none
left to right direction
skinparam ranksep 20
skinparam nodesep 5
hide stereotype

<style>
  root {
    BackgroundColor: #ffffff;
    FontColor: #444444;
  }
  // Element
  .Element-RWxlbWVudA== {
    BackgroundColor: #000000;
    LineColor: #000000;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,AnalyticsPipe
  .Element-RWxlbWVudCxBbmFseXRpY3NQaXBl {
    BackgroundColor: #218c74;
    LineColor: #176251;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Broker
  .Element-RWxlbWVudCxCcm9rZXI= {
    BackgroundColor: #4b7bec;
    LineColor: #3456a5;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Observability
  .Element-RWxlbWVudCxPYnNlcnZhYmlsaXR5 {
    BackgroundColor: #8e44ad;
    LineColor: #632f79;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Person
  .Element-RWxlbWVudCxQZXJzb24= {
    BackgroundColor: #08427b;
    LineColor: #052e56;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Prod
  .Element-RWxlbWVudCxQcm9k {
    BackgroundColor: #1168bd;
    LineColor: #0b4884;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Relationship
  .Relationship-UmVsYXRpb25zaGlw {
    LineThickness: 2;
    LineStyle: 10-10;
    LineColor: #444444;
    FontColor: #444444;
    FontSize: 24;
  }
  // Relationship,Publish
  .Relationship-UmVsYXRpb25zaGlwLFB1Ymxpc2g= {
    LineThickness: 2;
    LineStyle: 10-10;
    LineColor: #e67e22;
    FontColor: #e67e22;
    FontSize: 24;
  }
  // Relationship,Subscribe
  .Relationship-UmVsYXRpb25zaGlwLFN1YnNjcmliZQ== {
    LineThickness: 2;
    LineStyle: 10-10;
    LineColor: #f1c40f;
    FontColor: #f1c40f;
    FontSize: 24;
  }
  // GoFuture Platform
  .Boundary-R29GdXR1cmUgUGxhdGZvcm0= {
    BackgroundColor: #ffffff;
    LineColor: #000000;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
  }
  // Analytics
  .Group-QW5hbHl0aWNz {
    BackgroundColor: #ffffff;
    LineColor: #444444;
    LineStyle: 2-2;
    LineThickness: 2;
    FontColor: #444444;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
  }
  // Analytics pipe
  .Group-QW5hbHl0aWNzIHBpcGU= {
    BackgroundColor: #ffffff;
    LineColor: #444444;
    LineStyle: 2-2;
    LineThickness: 2;
    FontColor: #444444;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
  }
  // Observability
  .Group-T2JzZXJ2YWJpbGl0eQ== {
    BackgroundColor: #ffffff;
    LineColor: #444444;
    LineStyle: 2-2;
    LineThickness: 2;
    FontColor: #444444;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
  }
</style>

rectangle "==Корпоративный менеджер\n<size:16>[Person]</size>\n\nУправляет счетами и поездками" <<Element-RWxlbWVudCxQZXJzb24=>> as Корпоративныйменеджер

rectangle "GoFuture Platform\n<size:16>[Software System]</size>" <<Boundary-R29GdXR1cmUgUGxhdGZvcm0=>> {
  rectangle "Analytics" <<Group-QW5hbHl0aWNz>> as groupQW5hbHl0aWNz {
    rectangle "==Analytics Service Tasks\n<size:16>[Container: Celery Task]</size>\n\nАсинхронная аналитика" <<Element-RWxlbWVudCxQcm9k>> as GoFuturePlatform.AnalyticsServiceTasks
  }

  rectangle "Analytics pipe" <<Group-QW5hbHl0aWNzIHBpcGU=>> as groupQW5hbHl0aWNzIHBpcGU= {
    rectangle "==Data Quality / Business Rules Validation\n<size:16>[Container: Great Expectations / Python]</size>\n\nПроверяет смысл данных, на которых будет учиться ML." <<Element-RWxlbWVudCxBbmFseXRpY3NQaXBl>> as GoFuturePlatform.DataQualityBusinessRulesValidation
    rectangle "==ML Platform\n<size:16>[Container: Kubeflow / MLflow]</size>\n\nОбучение и Serving моделей (Pricing, Fraud, Demand)" <<Element-RWxlbWVudCxBbmFseXRpY3NQaXBl>> as GoFuturePlatform.MLPlatform
    rectangle "==Analytics Engine\n<size:16>[Container: Spark/Flink]</size>\n\nОбработка аналитических данных" <<Element-RWxlbWVudCxBbmFseXRpY3NQaXBl>> as GoFuturePlatform.AnalyticsEngine
    rectangle "==Analytics Db\n<size:16>[Container: ClickHouse]</size>\n\nХранение аналитических данных" <<Element-RWxlbWVudCxBbmFseXRpY3NQaXBl>> as GoFuturePlatform.AnalyticsDb
    rectangle "==DataLens\n<size:16>[Container: BI Tool]</size>\n\nВизуализация бизнес метрик" <<Element-RWxlbWVudCxBbmFseXRpY3NQaXBl>> as GoFuturePlatform.DataLens
  }

  rectangle "Observability" <<Group-T2JzZXJ2YWJpbGl0eQ==>> as groupT2JzZXJ2YWJpbGl0eQ== {
    rectangle "==Grafana\n<size:16>[Container: Grafana]</size>\n\nВизуализация метрик. Дашборды" <<Element-RWxlbWVudCxPYnNlcnZhYmlsaXR5>> as GoFuturePlatform.Grafana
  }

  queue "==Брокер сообщений EDA\n<size:16>[Container: Kafka]</size>\n\nДоменные события, CDC события, события аналитики" <<Element-RWxlbWVudCxCcm9rZXI=>> as GoFuturePlatform.БрокерсообщенийEDA
  rectangle "==Data Contract / Schema Validation\n<size:16>[Container: Confluent Schema Registry]</size>\n\nПроверяет соответствие схеме (Schema Registry), наличие обязательных полей." <<Element-RWxlbWVudA==>> as GoFuturePlatform.DataContractSchemaValidation
}

GoFuturePlatform.БрокерсообщенийEDA --> GoFuturePlatform.AnalyticsServiceTasks <<Relationship-UmVsYXRpb25zaGlwLFN1YnNjcmliZQ==>> : "Задачи аналитики\n<size:16>[Subscribe]</size>"
GoFuturePlatform.AnalyticsServiceTasks --> GoFuturePlatform.AnalyticsEngine <<Relationship-UmVsYXRpb25zaGlw>> : "обработка данных\n<size:16>[Spark Jobs]</size>"
GoFuturePlatform.БрокерсообщенийEDA --> GoFuturePlatform.AnalyticsEngine <<Relationship-UmVsYXRpb25zaGlwLFN1YnNjcmliZQ==>> : "Поток событий для аналитики\n<size:16>[Subscribe]</size>"
GoFuturePlatform.AnalyticsEngine --> GoFuturePlatform.DataContractSchemaValidation <<Relationship-UmVsYXRpb25zaGlw>> : "Metadata/Schema fetch"
GoFuturePlatform.AnalyticsEngine --> GoFuturePlatform.DataQualityBusinessRulesValidation <<Relationship-UmVsYXRpb25zaGlw>> : "Транслирует обработанные и вычисленные данные"
GoFuturePlatform.DataQualityBusinessRulesValidation --> GoFuturePlatform.AnalyticsDb <<Relationship-UmVsYXRpb25zaGlw>> : "Записывает высококачественные данные\n<size:16>[ETL]</size>"
GoFuturePlatform.AnalyticsDb --> GoFuturePlatform.MLPlatform <<Relationship-UmVsYXRpb25zaGlw>> : "Выборка исторических данных и признаков\n<size:16>[SQL]</size>"
GoFuturePlatform.БрокерсообщенийEDA --> GoFuturePlatform.MLPlatform <<Relationship-UmVsYXRpb25zaGlwLFN1YnNjcmliZQ==>> : "Поток событий для предсказания в реальном времени\n<size:16>[Subscribe]</size>"
GoFuturePlatform.MLPlatform --> GoFuturePlatform.БрокерсообщенийEDA <<Relationship-UmVsYXRpb25zaGlwLFB1Ymxpc2g=>> : "Результаты расчета в реальном времени\nSurgeFactor / FraudAlert\n<size:16>[Publish]</size>"
GoFuturePlatform.MLPlatform --> GoFuturePlatform.AnalyticsDb <<Relationship-UmVsYXRpb25zaGlw>> : "Метрики точности моделей"
GoFuturePlatform.AnalyticsDb --> GoFuturePlatform.DataLens <<Relationship-UmVsYXRpb25zaGlw>> : "Предоставляет данные\n<size:16>[SQL]</size>"
GoFuturePlatform.Grafana --> GoFuturePlatform.AnalyticsDb <<Relationship-UmVsYXRpb25zaGlw>> : "Бизнесовые метрики"
GoFuturePlatform.DataLens --> Корпоративныйменеджер <<Relationship-UmVsYXRpb25zaGlw>> : "Смотрит отчеты"

@enduml