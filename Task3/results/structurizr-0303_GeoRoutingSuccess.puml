@startuml
title <size:24>Успешное маршрутизирование в основной регион</size>\n<size:24>Геомаршрутизация: успех</size>

set separator none
left to right direction
skinparam ranksep 20
skinparam nodesep 5
hide stereotype

<style>
  root {
    BackgroundColor: #ffffff;
    FontColor: #444444;
  }
  // Element,Infrastructure
  .Element-RWxlbWVudCxJbmZyYXN0cnVjdHVyZQ== {
    BackgroundColor: #555555;
    LineColor: #3b3b3b;
    LineStyle: 0;
    LineThickness: 2;
    RoundCorner: 20;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Infrastructure,GeoRouting
  .Element-RWxlbWVudCxJbmZyYXN0cnVjdHVyZSxHZW9Sb3V0aW5n {
    BackgroundColor: #2c3e50;
    LineColor: #1e2b38;
    LineStyle: 0;
    LineThickness: 2;
    RoundCorner: 20;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Infrastructure,Safety
  .Element-RWxlbWVudCxJbmZyYXN0cnVjdHVyZSxTYWZldHk= {
    BackgroundColor: #c0392b;
    LineColor: #86271e;
    LineStyle: 0;
    LineThickness: 2;
    RoundCorner: 20;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Person
  .Element-RWxlbWVudCxQZXJzb24= {
    BackgroundColor: #08427b;
    LineColor: #052e56;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Safety
  .Element-RWxlbWVudCxTYWZldHk= {
    BackgroundColor: #c0392b;
    LineColor: #86271e;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Relationship
  .Relationship-UmVsYXRpb25zaGlw {
    LineThickness: 2;
    LineStyle: 10-10;
    LineColor: #444444;
    FontColor: #444444;
    FontSize: 24;
  }
  // Global Infrastructure
  .Boundary-R2xvYmFsIEluZnJhc3RydWN0dXJl {
    BackgroundColor: #ffffff;
    LineColor: #3b3b3b;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
  }
  // GoFuture Platform
  .Boundary-R29GdXR1cmUgUGxhdGZvcm0= {
    BackgroundColor: #ffffff;
    LineColor: #000000;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
  }
</style>

rectangle "GoFuture Platform\n<size:16>[Software System]</size>" <<Boundary-R29GdXR1cmUgUGxhdGZvcm0=>> {
  rectangle "==Regional Firewall\n<size:16>[Container]</size>\n\nФильтрует трафик" <<Element-RWxlbWVudCxJbmZyYXN0cnVjdHVyZSxTYWZldHk=>> as GoFuturePlatform.RegionalFirewall
  rectangle "==API Gateway\n<size:16>[Container: ???]</size>\n\nЕдиная точка входа, Auth, Rate Limiting" <<Element-RWxlbWVudCxJbmZyYXN0cnVjdHVyZQ==>> as GoFuturePlatform.APIGateway
}

rectangle "Global Infrastructure\n<size:16>[Software System]</size>" <<Boundary-R2xvYmFsIEluZnJhc3RydWN0dXJl>> {
  rectangle "==GeoDNS (Route 53)\n<size:16>[Container: AWS Route 53]</size>\n\nDNS-маршрутизация на основе геолокации и задержки" <<Element-RWxlbWVudCxJbmZyYXN0cnVjdHVyZSxHZW9Sb3V0aW5n>> as GlobalInfrastructure.GeoDNSRoute53
  rectangle "==Health Checker\n<size:16>[Container: AWS Route 53 Health Checks]</size>\n\nМониторинг доступности регионов. Может быть частью Route 53\nПроверяет каждые 30 сек, 3 неудачи = unhealthy." <<Element-RWxlbWVudCxJbmZyYXN0cnVjdHVyZQ==>> as GlobalInfrastructure.HealthChecker
  rectangle "==WAF & DDoS Protection edge node\n<size:16>[Container]</size>\n\nФильтрует атаки (DDoS, SQL-инъекции, XSS, попытки взлома авторизации)." <<Element-RWxlbWVudCxTYWZldHk=>> as GlobalInfrastructure.WAFDDoSProtectionedgenode
}

rectangle "==Пользователь\n<size:16>[Person]</size>" <<Element-RWxlbWVudCxQZXJzb24=>> as Пользователь

Пользователь --> GlobalInfrastructure.GeoDNSRoute53 <<Relationship-UmVsYXRpb25zaGlw>> : "1: DNS-запрос: api.gofuture.com"
GlobalInfrastructure.GeoDNSRoute53 --> GlobalInfrastructure.HealthChecker <<Relationship-UmVsYXRpb25zaGlw>> : "2: проверяет доступность основного региона"
GlobalInfrastructure.GeoDNSRoute53 <-- GlobalInfrastructure.HealthChecker <<Relationship-UmVsYXRpb25zaGlw>> : "3: Основной регион доступен"
Пользователь <-- GlobalInfrastructure.GeoDNSRoute53 <<Relationship-UmVsYXRpb25zaGlw>> : "4: IP основного региона"
Пользователь --> GlobalInfrastructure.WAFDDoSProtectionedgenode <<Relationship-UmVsYXRpb25zaGlw>> : "5: HTTP-запрос в основной регион"
GlobalInfrastructure.WAFDDoSProtectionedgenode --> GoFuturePlatform.RegionalFirewall <<Relationship-UmVsYXRpb25zaGlw>> : "6: HTTP-запрос в основной регион\n<size:16>[HTTPS]</size>"
GoFuturePlatform.RegionalFirewall --> GoFuturePlatform.APIGateway <<Relationship-UmVsYXRpb25zaGlw>> : "7: HTTP-запрос в основной регион\n<size:16>[HTTPS]</size>"

@enduml