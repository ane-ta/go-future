GlobalInfrastructure.ReserveRegion.Mainregionprivatenetwork.KubernetesCluster.Instandbymode.APIGateway_1 --> GlobalInfrastructure.ReserveRegion.Mainregionprivatenetwork.KubernetesCluster.Broker_1 <<Relationship-UmVsYXRpb25zaGlw>> : "health check: metadata fetch\n<size:16>[Safety]</size>"
GlobalInfrastructure.ReserveRegion.Mainregionprivatenetwork.KubernetesCluster.Broker_1 --> GlobalInfrastructure.ReserveRegion.Mainregionprivatenetwork.KubernetesCluster.Instandbymode.ProdMicroservices_1 <<Relationship-UmVsYXRpb25zaGlwLFN1YnNjcmliZQ==>> : "Consume prod events\n<size:16>[Subscribe]</size>"
GlobalInfrastructure.ReserveRegion.Mainregionprivatenetwork.KubernetesCluster.Instandbymode.ProdMicroservices_1 --> GlobalInfrastructure.ReserveRegion.Mainregionprivatenetwork.KubernetesCluster.Broker_1 <<Relationship-UmVsYXRpb25zaGlwLFB1Ymxpc2g=>> : "Publish prod events\n<size:16>[Publish]</size>"
GlobalInfrastructure.ReserveRegion.Mainregionprivatenetwork.KubernetesCluster.Instandbymode.APIGateway_1 --> GlobalInfrastructure.ReserveRegion.Mainregionprivatenetwork.KubernetesCluster.БДМикросервисов_1 <<Relationship-UmVsYXRpb25zaGlw>> : "health check: SELECT 1\n<size:16>[Safety]</size>"
GlobalInfrastructure.ReserveRegion.Mainregionprivatenetwork.KubernetesCluster.Instandbymode.ProdMicroservices_1 --> GlobalInfrastructure.ReserveRegion.Mainregionprivatenetwork.KubernetesCluster.БДМикросервисов_1 <<Relationship-UmVsYXRpb25zaGlw>> : "Read Write\n<size:16>[SQL]</size>"

@enduml