GlobalInfrastructure.MainRegion.Mainregionprivatenetwork.KubernetesCluster.Broker_1 --> GlobalInfrastructure.MainRegion.Mainregionprivatenetwork.KubernetesCluster.Inactivemode.ProdMicroservices_1 <<Relationship-UmVsYXRpb25zaGlwLFN1YnNjcmliZQ==>> : "Consume prod events\n<size:16>[Subscribe]</size>"
GlobalInfrastructure.MainRegion.Mainregionprivatenetwork.KubernetesCluster.Inactivemode.ProdMicroservices_1 --> GlobalInfrastructure.MainRegion.Mainregionprivatenetwork.KubernetesCluster.Broker_1 <<Relationship-UmVsYXRpb25zaGlwLFB1Ymxpc2g=>> : "Publish prod events\n<size:16>[Publish]</size>"
GlobalInfrastructure.MainRegion.Mainregionprivatenetwork.KubernetesCluster.Inactivemode.APIGateway_1 --> GlobalInfrastructure.MainRegion.Mainregionprivatenetwork.KubernetesCluster.БДМикросервисов_1 <<Relationship-UmVsYXRpb25zaGlw>> : "health check: SELECT 1\n<size:16>[Safety]</size>"
GlobalInfrastructure.MainRegion.Mainregionprivatenetwork.KubernetesCluster.Inactivemode.ProdMicroservices_1 --> GlobalInfrastructure.MainRegion.Mainregionprivatenetwork.KubernetesCluster.БДМикросервисов_1 <<Relationship-UmVsYXRpb25zaGlw>> : "Read Write\n<size:16>[SQL]</size>"
