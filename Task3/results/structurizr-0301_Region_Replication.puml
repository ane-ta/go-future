@startuml
title <size:24>Репликация основного региона</size>

set separator none
left to right direction
skinparam ranksep 20
skinparam nodesep 5
hide stereotype

<style>
  root {
    BackgroundColor: #ffffff;
    FontColor: #444444;
  }
  // Element
  .Element-RWxlbWVudA== {
    BackgroundColor: #000000;
    LineColor: #000000;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Broker
  .Element-RWxlbWVudCxCcm9rZXI= {
    BackgroundColor: #4b7bec;
    LineColor: #3456a5;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Prod
  .Element-RWxlbWVudCxQcm9k {
    BackgroundColor: #1168bd;
    LineColor: #0b4884;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Prod,Database
  .Element-RWxlbWVudCxQcm9kLERhdGFiYXNl {
    BackgroundColor: #1c62b9;
    LineColor: #134481;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Prod,Standby
  .Element-RWxlbWVudCxQcm9kLFN0YW5kYnk= {
    BackgroundColor: #e0e0e0;
    LineColor: #9c9c9c;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #888888;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Element,Safety
  .Element-RWxlbWVudCxTYWZldHk= {
    BackgroundColor: #c0392b;
    LineColor: #86271e;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
    MaximumWidth: 450;
  }
  // Relationship
  .Relationship-UmVsYXRpb25zaGlw {
    LineThickness: 2;
    LineStyle: 10-10;
    LineColor: #444444;
    FontColor: #444444;
    FontSize: 24;
  }
  // Relationship,Publish
  .Relationship-UmVsYXRpb25zaGlwLFB1Ymxpc2g= {
    LineThickness: 2;
    LineStyle: 10-10;
    LineColor: #e67e22;
    FontColor: #e67e22;
    FontSize: 24;
  }
  // Relationship,Subscribe
  .Relationship-UmVsYXRpb25zaGlwLFN1YnNjcmliZQ== {
    LineThickness: 2;
    LineStyle: 10-10;
    LineColor: #f1c40f;
    FontColor: #f1c40f;
    FontSize: 24;
  }
  // Element
  .DeploymentNode-RWxlbWVudA== {
    BackgroundColor: #000000;
    LineColor: #000000;
    LineStyle: 0;
    LineThickness: 2;
    FontColor: #fffffe;
    FontSize: 24;
    HorizontalAlignment: center;
    Shadowing: 0;
  }
</style>

rectangle "Active region private network\n<size:16>[Deployment Node]</size>" <<DeploymentNode-RWxlbWVudA==>> as ActivePassiveRegionDeployment.Activeregionprivatenetwork {
  rectangle "K8 cluster\n<size:16>[Deployment Node]</size>" <<DeploymentNode-RWxlbWVudA==>> as ActivePassiveRegionDeployment.Activeregionprivatenetwork.K8cluster {
    rectangle "In active mode\n<size:16>[Deployment Node]</size>" <<DeploymentNode-RWxlbWVudA==>> as ActivePassiveRegionDeployment.Activeregionprivatenetwork.K8cluster.Inactivemode {
      rectangle "==Prod Microservices\n<size:16>[Container: Python/Faust Streaming]</size>\n\nбизнес логика после миграции" <<Element-RWxlbWVudCxQcm9k>> as ActivePassiveRegionDeployment.Activeregionprivatenetwork.K8cluster.Inactivemode.ProdMicroservices_1
    }

    database "==БД Микросервисов\n<size:16>[Container: PostgreSQL]</size>\n\nИсточники правды для микросервисов" <<Element-RWxlbWVudCxQcm9kLERhdGFiYXNl>> as ActivePassiveRegionDeployment.Activeregionprivatenetwork.K8cluster.БДМикросервисов_1
    queue "==Broker\n<size:16>[Container: Kafka]</size>\n\nсреда для EDA" <<Element-RWxlbWVudCxCcm9rZXI=>> as ActivePassiveRegionDeployment.Activeregionprivatenetwork.K8cluster.Broker_1
    rectangle "Kafka Connect In emit-mode\n<size:16>[Deployment Node]</size>" <<DeploymentNode-RWxlbWVudA==>> as ActivePassiveRegionDeployment.Activeregionprivatenetwork.K8cluster.KafkaConnectInemitmode {
      rectangle "==Debezium Source Connector\n<size:16>[Infrastructure Node]</size>\n\nЧитает WAL PostgreSQL → публикует в Kafka" <<Element-RWxlbWVudA==>> as ActivePassiveRegionDeployment.Activeregionprivatenetwork.K8cluster.KafkaConnectInemitmode.DebeziumSourceConnector
    }

  }

  rectangle "==Regional Firewall\n<size:16>[Infrastructure Node: passiveGroup]</size>\n\nactiveGroup," <<Element-RWxlbWVudCxTYWZldHk=>> as ActivePassiveRegionDeployment.Activeregionprivatenetwork.RegionalFirewall
}

rectangle "Passive region private network\n<size:16>[Deployment Node]</size>" <<DeploymentNode-RWxlbWVudA==>> as ActivePassiveRegionDeployment.Passiveregionprivatenetwork {
  rectangle "k8 cluster\n<size:16>[Deployment Node]</size>" <<DeploymentNode-RWxlbWVudA==>> as ActivePassiveRegionDeployment.Passiveregionprivatenetwork.k8cluster {
    rectangle "In standby mode\n<size:16>[Deployment Node]</size>" <<DeploymentNode-RWxlbWVudA==>> as ActivePassiveRegionDeployment.Passiveregionprivatenetwork.k8cluster.Instandbymode {
      rectangle "==Prod Microservices\n<size:16>[Container: Python/Faust Streaming]</size>\n\nбизнес логика после миграции" <<Element-RWxlbWVudCxQcm9kLFN0YW5kYnk=>> as ActivePassiveRegionDeployment.Passiveregionprivatenetwork.k8cluster.Instandbymode.ProdMicroservices_1
    }

    database "==БД Микросервисов\n<size:16>[Container: PostgreSQL]</size>\n\nИсточники правды для микросервисов" <<Element-RWxlbWVudCxQcm9kLERhdGFiYXNl>> as ActivePassiveRegionDeployment.Passiveregionprivatenetwork.k8cluster.БДМикросервисов_1
    queue "==Broker\n<size:16>[Container: Kafka]</size>\n\nсреда для EDA" <<Element-RWxlbWVudCxCcm9rZXI=>> as ActivePassiveRegionDeployment.Passiveregionprivatenetwork.k8cluster.Broker_1
    rectangle "==Mirror Maker 2\n<size:16>[Infrastructure Node: Duplication]</size>\n\nДупликация потока событий" <<Element-RWxlbWVudA==>> as ActivePassiveRegionDeployment.Passiveregionprivatenetwork.k8cluster.MirrorMaker2
    rectangle "Kafka Connect In consume-mode\n<size:16>[Deployment Node]</size>" <<DeploymentNode-RWxlbWVudA==>> as ActivePassiveRegionDeployment.Passiveregionprivatenetwork.k8cluster.KafkaConnectInconsumemode {
      rectangle "==JDBC Sink Connector\n<size:16>[Infrastructure Node]</size>\n\nЧитает из Kafka → пишет в PostgreSQL" <<Element-RWxlbWVudA==>> as ActivePassiveRegionDeployment.Passiveregionprivatenetwork.k8cluster.KafkaConnectInconsumemode.JDBCSinkConnector
    }

  }

  rectangle "==Regional Firewall\n<size:16>[Infrastructure Node: activeGroup]</size>\n\npassiveGroup," <<Element-RWxlbWVudCxTYWZldHk=>> as ActivePassiveRegionDeployment.Passiveregionprivatenetwork.RegionalFirewall
}

rectangle "Global infrastructure\n<size:16>[Deployment Node]</size>" <<DeploymentNode-RWxlbWVudA==>> as ActivePassiveRegionDeployment.Globalinfrastructure {
  rectangle "==Transit Firewall\n<size:16>[Container]</size>\n\nГарантирует, что через этот канал идет только поток Kafka/CDC и ничего больше" <<Element-RWxlbWVudCxTYWZldHk=>> as ActivePassiveRegionDeployment.Globalinfrastructure.TransitFirewall_1
}

ActivePassiveRegionDeployment.Activeregionprivatenetwork.K8cluster.Inactivemode.ProdMicroservices_1 --> ActivePassiveRegionDeployment.Activeregionprivatenetwork.K8cluster.БДМикросервисов_1 <<Relationship-UmVsYXRpb25zaGlw>> : "Read Write\n<size:16>[SQL]</size>"
ActivePassiveRegionDeployment.Activeregionprivatenetwork.K8cluster.Broker_1 --> ActivePassiveRegionDeployment.Activeregionprivatenetwork.K8cluster.Inactivemode.ProdMicroservices_1 <<Relationship-UmVsYXRpb25zaGlwLFN1YnNjcmliZQ==>> : "Consume prod events\n<size:16>[Subscribe]</size>"
ActivePassiveRegionDeployment.Activeregionprivatenetwork.K8cluster.Inactivemode.ProdMicroservices_1 --> ActivePassiveRegionDeployment.Activeregionprivatenetwork.K8cluster.Broker_1 <<Relationship-UmVsYXRpb25zaGlwLFB1Ymxpc2g=>> : "Publish prod events\n<size:16>[Publish]</size>"
ActivePassiveRegionDeployment.Activeregionprivatenetwork.K8cluster.KafkaConnectInemitmode.DebeziumSourceConnector --> ActivePassiveRegionDeployment.Activeregionprivatenetwork.K8cluster.Broker_1 <<Relationship-UmVsYXRpb25zaGlwLFB1Ymxpc2g=>> : "CDC events\n<size:16>[Publish]</size>"
ActivePassiveRegionDeployment.Activeregionprivatenetwork.K8cluster.БДМикросервисов_1 --> ActivePassiveRegionDeployment.Activeregionprivatenetwork.K8cluster.KafkaConnectInemitmode.DebeziumSourceConnector <<Relationship-UmVsYXRpb25zaGlw>> : "Transaction logs (WAL)\n<size:16>[PostgreSQL logical replication]</size>"
ActivePassiveRegionDeployment.Activeregionprivatenetwork.K8cluster.Broker_1 --> ActivePassiveRegionDeployment.Activeregionprivatenetwork.RegionalFirewall <<Relationship-UmVsYXRpb25zaGlwLFN1YnNjcmliZQ==>> : "CDC, EDA events, consumer offsets to mirror\n<size:16>[Subscribe]</size>"
ActivePassiveRegionDeployment.Passiveregionprivatenetwork.k8cluster.MirrorMaker2 --> ActivePassiveRegionDeployment.Passiveregionprivatenetwork.k8cluster.Broker_1 <<Relationship-UmVsYXRpb25zaGlwLFB1Ymxpc2g=>> : "CDC, EDA events, consumer offsets\n<size:16>[Publish]</size>"
ActivePassiveRegionDeployment.Passiveregionprivatenetwork.k8cluster.Broker_1 --> ActivePassiveRegionDeployment.Passiveregionprivatenetwork.k8cluster.KafkaConnectInconsumemode.JDBCSinkConnector <<Relationship-UmVsYXRpb25zaGlwLFN1YnNjcmliZQ==>> : "CDC events\n<size:16>[Subscribe]</size>"
ActivePassiveRegionDeployment.Passiveregionprivatenetwork.k8cluster.KafkaConnectInconsumemode.JDBCSinkConnector --> ActivePassiveRegionDeployment.Passiveregionprivatenetwork.k8cluster.БДМикросервисов_1 <<Relationship-UmVsYXRpb25zaGlw>> : "apply db changes\n<size:16>[SQL]</size>"
ActivePassiveRegionDeployment.Passiveregionprivatenetwork.RegionalFirewall --> ActivePassiveRegionDeployment.Passiveregionprivatenetwork.k8cluster.MirrorMaker2 <<Relationship-UmVsYXRpb25zaGlwLFN1YnNjcmliZQ==>> : "CDC, EDA events, consumer offsets to mirror\n<size:16>[Subscribe]</size>"
ActivePassiveRegionDeployment.Activeregionprivatenetwork.RegionalFirewall --> ActivePassiveRegionDeployment.Globalinfrastructure.TransitFirewall_1 <<Relationship-UmVsYXRpb25zaGlwLFN1YnNjcmliZQ==>> : "CDC, EDA events, consumer offsets to mirror (encrypted)\n<size:16>[mTLS/VPN]</size>"
ActivePassiveRegionDeployment.Globalinfrastructure.TransitFirewall_1 --> ActivePassiveRegionDeployment.Passiveregionprivatenetwork.RegionalFirewall <<Relationship-UmVsYXRpb25zaGlwLFN1YnNjcmliZQ==>> : "CDC, EDA events, consumer offsets to mirror (encrypted)\n<size:16>[mTLS/VPN]</size>"

@enduml